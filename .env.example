# ─── Site URL ────────────────────────────────────────────────────────────────
# Used for absolute-URL generation in emails, sitemaps, and OG tags.
# Set this in Vercel → Settings → Environment Variables.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── OpenAI (optional — required for vector retrieval) ───────────────────────
# When set alongside SUPABASE_URL + key, the app switches from rule-based
# retrieval to semantic vector retrieval with rule-based fallback.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Supabase (optional — required for vector retrieval) ─────────────────────
# Create the table and RPC by running supabase/resume_chunks.sql in the
# Supabase SQL editor, then fill in the values below.
#
# Use the service-role key for the ingestion script (scripts/ingest.ts) and
# the /api/reindex endpoint so they can write to the table.
# The anon key is sufficient for the read-only RPC called by /api/chat.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# RPC function name defined in supabase/resume_chunks.sql (default is fine).
SUPABASE_RETRIEVAL_RPC=match_resume_chunks

# ─── Reindex endpoint protection (optional, recommended in production) ────────
# If set, POST /api/reindex requires the header:
#   Authorization: Bearer <value>
# Leave blank for local development — the check is skipped outside production.
REINDEX_SECRET=
